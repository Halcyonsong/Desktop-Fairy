{
  "name": "desktop-fairy-workbench",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "electron:dev": "electron electron/main.cjs",
    "desktop:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && electron electron/main.cjs\"",
    "desktop:build": "npm run build",
    "desktop:prepare": "node electron/prepare-package.cjs",
    "desktop:pack": "npm run desktop:build && npm run desktop:prepare && electron-builder --win nsis"
  },
  "dependencies": {
    "@lucide/vue": "^1.24.0",
    "katex": "^0.17.0",
    "koffi": "^2.9.0",
    "pinia": "^2.3.0",
    "vosk-browser": "^0.0.8",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "electron": "33.2.1",
    "electron-builder": "^26.0.12",
    "typescript": "~5.6.3",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "io.github.halcyonsong.desktopfairy",
    "productName": "Desktop Fairy",
    "directories": {
      "output": "release"
    },
    "electronDist": "../temp",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*",
      "node_modules/koffi/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/koffi/**/*"
    ],
    "extraResources": [
      {
        "from": "bundle-staging/backend",
        "to": "backend"
      },
      {
        "from": "bundle-staging/local-model-scripts",
        "to": "local-model-scripts"
      },
      {
        "from": "bundle-staging/runtime",
        "to": "runtime"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
